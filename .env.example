# Slack App Credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# CMU Credentials (for TPR form)
CMU_ANDREW_ID=your-andrew-id
CMU_PASSWORD=your-password

# Google API
GOOGLE_CREDENTIALS_PATH=credentials/google_credentials.json

# VLM - Receipt Processing (Ollama is tried first, Gemini is fallback)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-vl:7b
OLLAMA_TIMEOUT=120
OLLAMA_ENABLED=true

# Gemini API (fallback when Ollama unavailable)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Database
DATABASE_URL=postgresql://finance_bot:your-password@localhost:5432/finance_bot

# Clerk Authentication (ScottyLabs CMU SSO)
# Get these from ScottyLabs — see their Clerk setup docs
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_FRONTEND_API=clerk.scottylabs.org
CLERK_SIGN_IN_URL=https://scottylabs.org/sign-in
CLERK_SIGN_UP_URL=https://scottylabs.org/sign-up

# File paths (use quotes for paths with spaces!)
RECEIPTS_FOLDER_PATH="Spring Carnival 2026/Finance/Receipts/Invoices"
BUDGET_SPREADSHEET_PATH="FY2026 Budget"
TPR_TRACKING_SHEET_PATH="TPR Tracking Sheet"
